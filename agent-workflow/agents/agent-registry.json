      "data_center_v4_production",
      "v3_internal_card_compatibility",
      "page_contract_typography"
    ],
    "requirement": "高风险流程派发、执行和 closeout 必须说明使用的 harness、固定读取、质量门和下游放行结论。"
  },
  "agents": [
    {
      "id": "product-commander",
      "name": "Product Commander",
      "file": "agents/product-commander-agent.md",
      "process_node": "intake_decision_dispatch",
      "starts_first": true,
      "primary_outputs": ["产品判断", "任务拆解", "派发单", "验收标准", "看板状态"]
    },
    {
      "id": "intelligence-engine",
      "name": "Intelligence Engine",
      "file": "agents/data-agent.md",
      "process_node": "source_evidence_pool_card",
      "primary_outputs": ["来源规则", "Raw / Pool 规则", "Card 资产规则", "结构化素材资产", "标签关系", "质量报告"]
    },
    {
      "id": "experience-editorial",
      "name": "Experience & Editorial",
      "file": "agents/experience-editorial-agent.md",
      "process_node": "content_ux_expression",
      "primary_outputs": ["页面结构表", "Typography 表", "Copy-first 文案表", "栏目表达规则", "桌面验收点"]
    },
    {
      "id": "build-release",
      "name": "Build & Release",
      "file": "agents/build-release-agent.md",
      "process_node": "build_gate_release",
      "primary_outputs": ["代码改动", "脚本实现", "质量门结果", "发布状态", "风险说明"]
