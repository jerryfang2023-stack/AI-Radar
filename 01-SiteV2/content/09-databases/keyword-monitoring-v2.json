  "owner": "Intelligence Data Agent / Workflow Agent",
  "purpose": "Executable keyword and signal-class monitoring config for WaveSight AI V2 daily source-router. This version restores V4.2 keyword-list coverage for mature signals, early signals, technical iteration signals, and developer ecosystem signals.",
  "policy": {
    "raw_max_theme_share": 0.35,
    "pool_max_theme_share": 0.4,
    "structured_max_same_theme": 4,
    "front_signal_default_max_same_theme": 1,
    "front_signal_theme_day_max_same_theme": 2,
    "theme_day_requires_note": true,
    "required_daily_theme_groups": 4,
    "required_signal_classes": [
      "mature-commercial-signal",
      "early-direction-signal",
      "technical-iteration-signal",
      "developer-ecosystem-signal"
    ],
    "raw_min_per_required_signal_class": 8,
    "pool_min_per_required_signal_class": 3,
    "p0_tracks_are_anchors_not_boundaries": true,
    "exploration_query_share": 0.15,
    "outside_core_track_min_raw": 10,
    "outside_core_track_rule": "P0 core tracks are monitoring anchors, not content boundaries. Keep a daily exploratory lane for industries, workflows and weak signals outside the current core tracks.",
    "keyword_search_mode": "multi_path_evidence_search",
    "keyword_search_paths_required": [
      "official_original",
      "developer_ecosystem",
      "capital_startup",
      "industry_landing",
      "procurement_marketplace",
      "a_media_gdelt",
      "community_feedback"
    ],
    "keyword_search_non_community_required": true,
    "keyword_search_community_only_policy": "If keyword-search only finds HN/Reddit/X/community discussion, keep the item in Watchlist or User Feedback Pool and continue searching official, developer ecosystem, startup/funding, industry, procurement/marketplace, and A-media sources before formal Pool or frontstage use.",
    "anti_big_company_bias_rule": "For AI applications, industry landing, tool ecosystems, workflow change, Agent, vertical SaaS and enterprise service themes, add startup, YC, Product Hunt, GitHub, Hugging Face, marketplace, customer story, vertical SaaS, industry use case, and AI agent for + industry/role/workflow queries.",
    "front_signal_target_mix": {
      "mature-commercial-signal": "1-2",
      "early-direction-signal": "1",
      "technical-iteration-signal": "0-1",
      "developer-ecosystem-signal": "0-1"
    },
    "warning_threshold_share": 0.4
  },
  "raw_entry_policy": {
    "default_strategy": "AI HOT full 24h + follow-builders + keyword rules first; external multi-path search only when Raw target is not reached or important cards need S/A/B evidence補证.",
    "aihot_role": "primary_raw_discovery_entrance",
    "aihot_mode": "all",
    "aihot_window_hours": 24,
    "aihot_default_candidate_categories": ["ai-products", "ai-models"],
    "aihot_conditional_candidate_categories": {
      "paper": "Paper items enter Raw Candidate only when they match technical iteration terms, business actions, developer ecosystem terms, or explicit application scenarios."
    },
    "aihot_keyword_required_categories": ["tip"],
    "aihot_fallback_rule": "AI HOT itself is M-level discovery. Eligible items enter Raw Candidate only after category / keyword / business-action screening; important cards must fetch the original URL and resolve S/A/B evidence.",
    "follow_builders_role": "full_daily_frontier_opinion_library",
    "follow_builders_rule": "Every daily follow-builders item is written to the frontier opinion library. It may enter Raw / Pool when relevant, but social or community posts are viewpoint evidence and cannot prove company facts without S/A/B補证.",
    "external_search_activation": [
      "AI HOT filtered candidates + follow-builders are below the configured Raw target",
      "required signal classes are under-covered",
      "important card candidates lack S/A/B original evidence",
      "AI HOT origin fetch fails or only produces discovery_only / weak_signal text"
    ],
    "important_card_backfill_rule": "Change cards, case cards, trend reports, daily observation and business brief claims must resolve original S/A/B evidence where public information exists. C/M discovery can trigger watch, heatmap or user-feedback pools but cannot stand alone as fact-main evidence.",
